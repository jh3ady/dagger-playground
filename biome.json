{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "files": {
    "includes": [
      "experiments/**/ts/src/**/*.ts",
      "experiments/**/ts/*.ts",
      "experiments/**/ts/*.json",
      "**/*.json",
      "**/*.md"
    ],
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/.dagger",
      "**/*.min.*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
